<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/book-recommender#"
     xml:base="http://example.org/book-recommender"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.org/book-recommender">
        <rdfs:comment>OWL ontology for a simple Semantic Web book recommendation system.</rdfs:comment>
    </owl:Ontology>

    <!-- Classes -->
    <owl:Class rdf:about="#Person"/>
    <owl:Class rdf:about="#User">
        <rdfs:subClassOf rdf:resource="#Person"/>
    </owl:Class>
    <owl:Class rdf:about="#Book"/>
    <owl:Class rdf:about="#Theme"/>
    <owl:Class rdf:about="#ReadingLevel"/>
    <owl:Class rdf:about="#Author">
        <rdfs:subClassOf rdf:resource="#Person"/>
    </owl:Class>
    <owl:Class rdf:about="#Recommendation"/>

    <!-- Object properties -->
    <owl:ObjectProperty rdf:about="#prefersTheme">
        <rdfs:domain rdf:resource="#User"/>
        <rdfs:range rdf:resource="#Theme"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hasReadingLevel">
        <rdfs:domain rdf:resource="#User"/>
        <rdfs:range rdf:resource="#ReadingLevel"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hasTheme">
        <rdfs:domain rdf:resource="#Book"/>
        <rdfs:range rdf:resource="#Theme"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#suitableForLevel">
        <rdfs:domain rdf:resource="#Book"/>
        <rdfs:range rdf:resource="#ReadingLevel"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hasAuthor">
        <rdfs:domain rdf:resource="#Book"/>
        <rdfs:range rdf:resource="#Author"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#recommendedFor">
        <rdfs:domain rdf:resource="#Book"/>
        <rdfs:range rdf:resource="#User"/>
    </owl:ObjectProperty>

    <!-- Data properties -->
    <owl:DatatypeProperty rdf:about="#title">
        <rdfs:domain rdf:resource="#Book"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#description">
        <rdfs:domain rdf:resource="#Book"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#userName">
        <rdfs:domain rdf:resource="#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#authorName">
        <rdfs:domain rdf:resource="#Author"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#themeName">
        <rdfs:domain rdf:resource="#Theme"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#levelName">
        <rdfs:domain rdf:resource="#ReadingLevel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- Reading level individuals -->
    <owl:NamedIndividual rdf:about="#Beginner">
        <rdf:type rdf:resource="#ReadingLevel"/>
        <levelName>Beginner</levelName>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Intermediate">
        <rdf:type rdf:resource="#ReadingLevel"/>
        <levelName>Intermediate</levelName>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Advanced">
        <rdf:type rdf:resource="#ReadingLevel"/>
        <levelName>Advanced</levelName>
    </owl:NamedIndividual>

    <!-- Theme individuals -->
    <owl:NamedIndividual rdf:about="#ScienceFiction">
        <rdf:type rdf:resource="#Theme"/>
        <themeName>Science Fiction</themeName>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Fantasy">
        <rdf:type rdf:resource="#Theme"/>
        <themeName>Fantasy</themeName>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Mystery">
        <rdf:type rdf:resource="#Theme"/>
        <themeName>Mystery</themeName>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Murder">
        <rdf:type rdf:resource="#Theme"/>
        <themeName>Murder</themeName>
    </owl:NamedIndividual>

    <!-- User individuals -->
    <owl:NamedIndividual rdf:about="#Alice">
        <rdf:type rdf:resource="#User"/>
        <userName>Alice</userName>
        <hasReadingLevel rdf:resource="#Intermediate"/>
        <prefersTheme rdf:resource="#ScienceFiction"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Bob">
        <rdf:type rdf:resource="#User"/>
        <userName>Bob</userName>
        <hasReadingLevel rdf:resource="#Beginner"/>
        <prefersTheme rdf:resource="#Mystery"/>
    </owl:NamedIndividual>

    <!-- Author individuals -->
    <owl:NamedIndividual rdf:about="#FrankHerbert">
        <rdf:type rdf:resource="#Author"/>
        <authorName>Frank Herbert</authorName>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#AlexMichaelides">
        <rdf:type rdf:resource="#Author"/>
        <authorName>Alex Michaelides</authorName>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#SuzanneCollins">
        <rdf:type rdf:resource="#Author"/>
        <authorName>Suzanne Collins</authorName>
    </owl:NamedIndividual>

    <!-- Book individuals -->
    <owl:NamedIndividual rdf:about="#Dune">
        <rdf:type rdf:resource="#Book"/>
        <title>Dune</title>
        <description>Science Fiction and Fantasy novel suitable for Advanced readers.</description>
        <hasAuthor rdf:resource="#FrankHerbert"/>
        <hasTheme rdf:resource="#ScienceFiction"/>
        <hasTheme rdf:resource="#Fantasy"/>
        <suitableForLevel rdf:resource="#Advanced"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#TheSilentPatient">
        <rdf:type rdf:resource="#Book"/>
        <title>The Silent Patient</title>
        <description>Mystery and Murder novel suitable for Intermediate readers.</description>
        <hasAuthor rdf:resource="#AlexMichaelides"/>
        <hasTheme rdf:resource="#Mystery"/>
        <hasTheme rdf:resource="#Murder"/>
        <suitableForLevel rdf:resource="#Intermediate"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#HungerGames">
        <rdf:type rdf:resource="#Book"/>
        <title>Hunger Games</title>
        <description>Science Fiction and Fantasy novel for Beginner readers only.</description>
        <hasAuthor rdf:resource="#SuzanneCollins"/>
        <hasTheme rdf:resource="#ScienceFiction"/>
        <hasTheme rdf:resource="#Fantasy"/>
        <suitableForLevel rdf:resource="#Beginner"/>
    </owl:NamedIndividual>

</rdf:RDF>
